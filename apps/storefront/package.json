{
  "name": "@azphalt/storefront",
  "version": "0.1.2",
  "private": true,
  "description": "The azphalt consignment marketplace storefront — a Next.js app on the open standard.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bundle": "next build && node scripts/bundle.mjs",
    "embed-docs": "node scripts/embed-docs.mjs",
    "seed": "tsx scripts/seed.ts",
    "clean": "rm -rf .next dist-server public/_docs"
  },
  "dependencies": {
    "@azphalt/azdk": "workspace:*",
    "@azphalt/azp": "workspace:*",
    "@azphalt/registry": "workspace:*",
    "@azphalt/registry-store-vercel": "workspace:*",
    "@azphalt/repository-server": "workspace:*",
    "@stripe/stripe-js": "^9.10.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.2",
    "tar-stream": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/tar-stream": "^3.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
