{
  "name": "@azphalt/example-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "A gallery of example azphalt packages — several per asset type and per extension kind. Doubles as a fixture set.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/build.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "@azphalt/azp": "workspace:*",
    "@azphalt/sdk": "workspace:*"
  },
  "devDependencies": {
    "@azphalt/runtime-wasm": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "@types/node": "^22.0.0"
  }
}
