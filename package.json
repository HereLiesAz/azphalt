{
  "name": "azphalt-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "fixtures": "pnpm --filter \"@azphalt/conformance...\" build && pnpm --filter @azphalt/conformance emit",
    "changeset": "changeset",
    "version": "0.1.1",
    "release": "pnpm build && pnpm test && changeset publish",
    "release:staged": "bash scripts/publish-staged.sh",
    "release:promote": "bash scripts/promote-latest.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "workspaces": [
    "packages/*",
    "packages/importers/*"
  ]
}

