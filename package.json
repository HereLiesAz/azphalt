{
  "name": "azphalt-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "fixtures": "pnpm --filter \"@azphalt/conformance...\" build && pnpm --filter @azphalt/conformance emit",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && pnpm test && changeset publish",
    "release:staged": "bash scripts/publish-staged.sh",
    "release:promote": "bash scripts/promote-latest.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "vite@<=6.4.2": "^6.4.3",
      "esbuild@<=0.24.2": ">=0.25.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
