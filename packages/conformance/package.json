{
  "name": "@azphalt/conformance",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "description": "A runnable conformance suite that certifies an azphalt host against the standard.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@azphalt/azp": "workspace:*", "@azphalt/sdk": "workspace:*" },
  "devDependencies": {
    "@azphalt/runtime-wasm": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false
}
