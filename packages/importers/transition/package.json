{
  "name": "@azphalt/importer-transition",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "description": "Import GL Transitions (gl-transitions.com) into .azp transition assets.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "azphalt-import-transition": "./dist/cli.js" },
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@azphalt/azp": "workspace:*", "@azphalt/sdk": "workspace:*" },
  "devDependencies": { "typescript": "^5.6.0", "vitest": "^4.1.10", "@types/node": "^22.0.0" },
  "sideEffects": false
}
