{
  "name": "@azphalt/mcp",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "description": "An MCP server exposing azphalt .azp verify/inspect/extract tools to any MCP host.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "azphalt-mcp": "./dist/bin.js" },
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azphalt/azp": "workspace:*",
    "@azphalt/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": { "typescript": "^5.6.0", "vitest": "^3.2.6", "@types/node": "^22.0.0" },
  "sideEffects": false
}
