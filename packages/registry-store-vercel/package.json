{
  "name": "@azphalt/registry-store-vercel",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A durable RegistryStore for @azphalt/registry backed by Neon Postgres + Vercel Blob.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@azphalt/registry": "workspace:*"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1"
  },
  "devDependencies": {
    "@azphalt/registry": "workspace:*",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "sideEffects": false
}
