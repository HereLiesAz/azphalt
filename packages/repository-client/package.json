{
  "name": "@azphalt/repository-client",
  "version": "0.1.1",
  "publishConfig": { "access": "public" },
  "description": "Client SDK for the azphalt Repository API.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@azphalt/azdk": "workspace:*" },
  "sideEffects": false
}
