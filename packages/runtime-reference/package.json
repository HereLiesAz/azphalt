{
    "name":  "@azphalt/runtime-reference",
    "version":  "0.1.0",
    "description":  "A reference host for executing azphalt extensions.",
    "license":  "MIT",
    "author":  "Az (https://hereliesaz.com)",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "default":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "test":  "vitest run",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "clean":  "rm -rf dist"
                },
    "dependencies":  {
                         "@azphalt/sdk":  "workspace:*",
                         "@azphalt/azp":  "workspace:*"
                     },
    "devDependencies":  {
                            "typescript":  "^5.6.0"
                        },
    "sideEffects":  false
}
