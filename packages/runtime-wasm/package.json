{
  "name": "@azphalt/runtime-wasm",
  "version": "0.1.1",
  "publishConfig": { "access": "public" },
  "description": "Run azphalt code extensions inside a QuickJS-in-WASM sandbox with capability-gated host functions.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@azphalt/azp": "workspace:*", "@azphalt/azdk": "workspace:*", "quickjs-emscripten": "^0.31.0" },
  "devDependencies": { "typescript": "^5.6.0", "vitest": "^3.2.6", "@types/node": "^22.0.0" },
  "sideEffects": false
}
