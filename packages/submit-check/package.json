{
  "name": "@azphalt/submit-check",
  "version": "0.1.2",
  "private": true,
  "description": "Validate registry submissions (submissions/<id>/) by packaging each into a verifiable .azp.",
  "license": "MIT",
  "author": "Az (https://hereliesaz.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "azphalt-submit-check": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate": "node dist/cli.js ../../submissions",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azphalt/azdk": "workspace:*",
    "@azphalt/azp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "sideEffects": false
}
